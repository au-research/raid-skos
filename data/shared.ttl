@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


# This file defines shared RAiD vocabularies 

# Language schema URI 

<https://vocabulary.raid.org/shared.language.schemaUri/scheme> a skos:ConceptScheme ;
	dcterms:title "Language Schema URI"@en ;
	dcterms:description "The URI of the language identifier schema used by RAiD."@en ;
	skos:hasTopConcept <https://www.iso.org/standard/74575.html> .
    
<https://www.iso.org/standard/74575.html> a skos:Concept ;
	skos:topConceptOf <https://vocabulary.raid.org/shared.language.schemaUri/scheme> ;
	skos:prefLabel "ISO 639:2023 (Set 3)"@en ;
	skos:altLabel "ISO 639:2023 Code for individual languages and language groups (Set 3)"@en ;
    rdfs:seeAlso <https://www.iso.org/standard/74575.html> .


# Organization id schema URI 

<https://vocabulary.raid.org/shared.organization.id.schemaUri/scheme> a skos:ConceptScheme ;
	dcterms:title "Organisation ID Schema URI"@en ;
	dcterms:description "The URI schema of organization id used by RAiD."@en ;
	skos:hasTopConcept <https://ror.org/> .
    
<https://ror.org/> a skos:Concept ;
	skos:topConceptOf <https://vocabulary.raid.org/shared.organization.id.schemaUri/scheme> ;
	skos:inScheme <https://vocabulary.raid.org/shared.organization.id.schemaUri/scheme> ;
	skos:prefLabel "Research Organization Registry (ROR)"@en ;
    rdfs:seeAlso <https://ror.org> .

