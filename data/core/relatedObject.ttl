@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Related object id schema URI 
<https://vocabulary.raid.org/relatedObject.schemaUri/scheme> a skos:ConceptScheme ;
	dcterms:title "Related Object ID Schema URI"@en ;
	skos:hasTopConcept 
        <https://doi.org/> ,
        <https://hdl.handle.net/> ,
        <https://archive.org/> ,
        <https://arks.org/> ,
        <https://scicrunch.org/resolver/> ,
        <https://www.isbn-international.org/> .
    
<https://doi.org/> a skos:Concept ; 
    skos:prefLabel "DOI" ;
    skos:definition "All DOIs, including IGSNs, CrossRef Publication IDs or Grant IDs, DataCite DOIs, instrument DOIs, etc."@en ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .

 <https://hdl.handle.net/> a skos:Concept ; 
    skos:prefLabel "Handle" ;
    skos:definition "All non-DOI handles."@en ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .

<https://archive.org/> a skos:Concept ;
    skos:prefLabel "Archive.org" ;
    skos:definition "Fallback for any Object that has no ID other than a webpage - a snapshot must be taken from archive.org and that link inserted into the RAiD."@en ; 
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .

<https://arks.org/> a skos:Concept ; 
    skos:prefLabel "ARK"@en ;
    skos:definition "ARK"@en ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .

<https://scicrunch.org/resolver/> a skos:Concept ; 
    skos:prefLabel "RRID"@en ;
    skos:definition "RRID"@en ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .

<https://www.isbn-international.org/> a skos:Concept ; 
    skos:prefLabel "ISBN"@en ;
    skos:definition "ISBN"@en ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.schemaUri/scheme> .


# Related object category schema URI 

<https://vocabulary.raid.org/relatedObject.category.schemaUri/scheme> a skos:ConceptScheme ;    
	dcterms:title "Related Object Category Schema URI"@en ;
    skos:hasTopConcept <https://vocabulary.raid.org/relatedObject.category.schemaUri/386> .

<https://vocabulary.raid.org/relatedObject.category.schemaUri/386> a skos:Concept ;
    skos:prefLabel "RAiD related object category schema" ;
    skos:inScheme <https://vocabulary.raid.org/relatedObject.category.schemaUri/scheme> ;
    skos:topConceptOf <https://vocabulary.raid.org/relatedObject.category.schemaUri/scheme> .



# Related object category id 

<https://vocabulary.raid.org/relatedObject.category.id/scheme> a skos:ConceptScheme ;   
    dcterms:title "Related Object Category ID" ;
    skos:hasTopConcept <https://vocabulary.raid.org/relatedObject.category.id/190> ;
    skos:hasTopConcept <https://vocabulary.raid.org/relatedObject.category.id/191> ;
    skos:hasTopConcept <https://vocabulary.raid.org/relatedObject.category.id/192> .

<https://vocabulary.raid.org/relatedObject.category.id/190> a skos:Concept ;
    skos:prefLabel "Output"@en ;
    skos:definition "A related object produced directly by the project and intended for publication or other external use"@en ;
	skos:inScheme <https://vocabulary.raid.org/relatedObject.category.id/scheme> ;
	skos:topConceptOf <https://vocabulary.raid.org/relatedObject.category.id/scheme> .

<https://vocabulary.raid.org/relatedObject.category.id/191> a skos:Concept ;
    skos:prefLabel "Input"@en ;
    skos:definition "A related object used or referenced by the project"@en ;
	skos:inScheme <https://vocabulary.raid.org/relatedObject.category.id/scheme> ;
	skos:topConceptOf <https://vocabulary.raid.org/relatedObject.category.id/scheme> .

<https://vocabulary.raid.org/relatedObject.category.id/192> a skos:Concept ;
    skos:prefLabel "Internal process document or artefact"@en ;
    skos:definition "A related object, such as a Data Management Plan, produced by the project for internal use"@en ;
	skos:inScheme <https://vocabulary.raid.org/relatedObject.category.id/scheme> ;
	skos:topConceptOf <https://vocabulary.raid.org/relatedObject.category.id/scheme> .

